{
  "name": "claude-conversation-parser",
  "version": "1.0.0",
  "description": "Parser for Claude Code JSONL conversation files",
  "author": "hexi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hexi/claude-conversation-parser"
  },
  "keywords": [
    "claude",
    "claude-code",
    "conversation",
    "parser",
    "jsonl",
    "ai",
    "anthropic",
    "cli"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
